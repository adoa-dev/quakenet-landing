---
import integrants from "@/data/integrants";
import { Image } from "astro:assets";
---

<section class="team team--padding bg-muted">
  <div class="team__container">
    <div class="team__content">
      <div class="team__text-group">
        <div class="team__badge">
          Nuestro Equipo
        </div>
        <h2 class="team__title">
          Conoce a Nuestros Integrantes
        </h2>
        <p class="team__description">
          Nuestro equipo de expertos en tecnología, ciencia de datos y gestión
          de riesgos trabaja incansablemente para desarrollar soluciones que
          ayuden a nuestros clientes a proteger sus operaciones y a sus
          empleados ante los desastres naturales.
        </p>
      </div>
      <div class="team__grid">
        {integrants.map((integrant) => (
          <article class="team__member">
            <Image
              src={integrant.avatar}
              alt={integrant.name}
              class={`team__avatar ${integrant.className}`}
            />
            <div class="team__member-info">
              <p class="team__member-name">{integrant.name}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
