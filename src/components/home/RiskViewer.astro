---
import SeismicRiskMapPeru from "./SeismicRiskMapPeru";
import "@/styles/modules/risk-viewer.css"
---

<section class="risk-visualization risk-visualization--padding bg-muted">
  <div class="risk-visualization__container">
    <div class="risk-visualization__header">
      <div class="risk-visualization__badge">
        Visualización de Riesgo Sísmico
      </div>
      <h2 class="risk-visualization__title">
        Visualiza los Riesgos Sísmicos de tu Negocio
      </h2>
      <p class="risk-visualization__description">
        El mapa interactivo de QuakeNet te permite evaluar los niveles de
        riesgo sísmico para cualquier ubicación, capacitándote para tomar
        decisiones informadas sobre las operaciones y planes de expansión de
        tu negocio.
      </p>
    </div>
    <div class="risk-visualization__map-wrapper">
      <div class="risk-visualization__map">
        <SeismicRiskMapPeru client:only />
        <div class="risk-visualization__legend">
          <div class="risk-visualization__legend-item">
            <div class="risk-visualization__indicator risk-visualization__indicator--high"></div>
            <span>Alto Riesgo</span>
          </div>
          <div class="risk-visualization__legend-item">
            <div class="risk-visualization__indicator risk-visualization__indicator--moderate"></div>
            <span>Riesgo Moderado</span>
          </div>
          <div class="risk-visualization__legend-item">
            <div class="risk-visualization__indicator risk-visualization__indicator--low"></div>
            <span>Bajo Riesgo</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

