---
import { Image } from "astro:assets";
import { ArrowRightIcon } from "lucide-react";
import HeroImg from "@/assets/hero_img.jpg";
import "@/styles/modules/hero.css";
---

<section class="hero hero--padding">
  <div class="hero__container">
    <div class="hero__grid">
      <div class="hero__content">
        <div class="hero__text-group">
          <h1 class="hero__title">
            Empoderando a las empresas para prepararse ante lo inesperado
          </h1>
          <p class="hero__description">
            QuakeNet utiliza IA, aprendizaje automático y big data para
            ayudar a las empresas a evaluar y mitigar los riesgos sísmicos,
            permitiéndoles tomar decisiones informadas y proteger sus
            operaciones.
          </p>
        </div>
        <div class="hero__button-group">
          <a
            href="#contacto-empresa"
            class="hero__button"
          >
            Solicitar acceso
            <ArrowRightIcon className="hero__icon" />
          </a>
        </div>
      </div>
      <div class="hero__image-wrapper">
        <Image
          src={HeroImg}
          width="550"
          height="550"
          alt="Hero"
          class="hero__image"
        />
      </div>
    </div>
  </div>
</section>
